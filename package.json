{
  "name": "book-tracker",
  "module": "src/index.ts",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:server": "bun run --watch src/index.ts",
    "dev:css": "bunx @tailwindcss/cli -i ./frontend/styles.css -o ./frontend/dist.css --watch",
    "build:css": "bunx @tailwindcss/cli -i ./frontend/styles.css -o ./frontend/dist.css --minify",
    "start": "bun run src/index.ts",
    "test": "bun test"
  },
  "type": "module",
  "private": true,
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.3",
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "elysia": "^1.4.29",
    "googleapis": "^173.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.3"
  }
}
